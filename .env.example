# Contact form (src/pages/api/send-message.ts) sends submissions to Telegram.
# Create a bot via @BotFather and use /getUpdates or @userinfobot to find your chat id.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional. Used by src/lib/github.ts at build time to fetch pinned repos via
# the GitHub GraphQL API (more reliable than HTML scraping; also avoids the
# 60/hr unauthenticated REST rate limit). Any classic token with no scopes
# works — pinned repo metadata is public.
GITHUB_TOKEN=
