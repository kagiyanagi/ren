---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="404 — Not Found">
  <section
    class="bg-black min-h-[100svh] w-full text-white flex items-center justify-center relative overflow-hidden px-4 sm:px-6"
  >
    <main class="w-full max-w-[640px] text-center space-y-4 sm:space-y-6">
      <h1 class="text-center">
        <span
          class="bg-white text-black px-4 py-1 inline-block text-lg sm:text-xl"
        >
          Error - 404
        </span>
      </h1>
      <p class="text-sm sm:text-base">An error has occurred. To continue:</p>
      <p class="text-sm sm:text-base leading-relaxed">
        * Return to the homepage.<br />
        * Send me an email about this error and try later.
      </p>
      <nav class="text-sm sm:text-base" aria-label="Not found navigation">
        <a
          href="/"
          class="px-2 py-1 hover:bg-white hover:text-black focus-visible:bg-white focus-visible:text-black focus-visible:outline-none"
        >
          index
        </a>
        <span class="mx-1 text-white/70">|</span>
        <a
          id="refresh-link"
          href="/"
          class="px-2 py-1 hover:bg-white hover:text-black focus-visible:bg-white focus-visible:text-black focus-visible:outline-none"
        >
          refresh
        </a>
      </nav>
    </main>
  </section>
  <script>
    const refresh = document.getElementById("refresh-link");
    refresh?.addEventListener("click", (e) => {
      e.preventDefault();
      window.location.reload();
    });
  </script>
</Layout>
